#!/usr/bin/env bash
set -Eeuo pipefail

PROGRAM="${0##*/}"
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${INFR_LIB_DIR:-/usr/local/libexec/infr}"
if [[ -f "${SELF_DIR}/1password_cli.sh" ]]; then
  LIB_DIR="$SELF_DIR"
fi
ENV_FILE="${INFR_ENV_FILE:-${LIB_DIR}/.env}"
if [[ ! -f "$ENV_FILE" && -f "${SELF_DIR}/../.env" ]]; then
  ENV_FILE="${SELF_DIR}/../.env"
fi
[[ -f "$ENV_FILE" ]] && set -a && source "$ENV_FILE" && set +a

INSPECT_CACHE_FILE="${INFR_INSPECT_CACHE:-$HOME/.cache/infr/inspect.env}"
LOG_DIR="${INFR_LOG_DIR:-$HOME/.cache/infr/logs}"
DEBUG_MODE="${INFR_DEBUG:-false}"

log() {
  printf '[%s] %s\n' "$PROGRAM" "$*"
}

die() {
  printf '[%s][error] %s\n' "$PROGRAM" "$*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Infra Bootstrap CLI

Usage:
  infr [bootstrap]            Install 1Password CLI, attempt automated login, and configure Git
  infr setup [targets...]     Inspect the system and interactively install missing ML tooling
                              When targets are provided, only run the specified setup steps.
  infr setup --debug          Prints full installation trace and logs
  infr inspect [--cached]     Print environment inspection (fresh by default, cached when requested)
  infr gc <subcommand>        Google Cloud helpers (subcommands: setup_project, create_bucket, upload)
  infr update                 Pull latest infra-bootstrap changes and refresh installed support files
  infr uninstall              Remove CLI, caches, and infra-bootstrap repository
  infr --help                Show this help

Environment:
  GIT_PAT                     GitHub personal access token used for Git configuration
  OP_SERVICE_ACCOUNT_TOKEN    1Password service account token (preferred for automated signin)
  OP_ACCOUNT_DOMAIN           1Password account domain (e.g. my.1password.com)
  OP_EMAIL                    1Password email (if using password + secret key flow)
  OP_SECRET_KEY               1Password secret key (if using password + secret key flow)
  OP_MASTER_PASSWORD          1Password master password (if using password + secret key flow)
  ML_ENV_DIR                  Target virtual environment for ML packages (default: ~/.infr/ml-venv)
  INFR_INSPECT_CACHE          Override location for cached inspection metadata (default: ~/.cache/infr/inspect.env)

Setup targets (infr setup hf op ...)
  python|py                   Python toolchain (python3 + pip)
  cuda|gpu                    CUDA drivers & toolkit
  docker                      Docker engine
  ml|ml_packages              ML Python packages (torch, transformers, etc.)
  wandb                       Weights & Biases CLI setup
  hf|huggingface              Hugging Face CLI setup
  op|1password                1Password CLI install/login helper
  git                         Git configuration helper
  gcloud|gsutil               Google Cloud SDK (gcloud + gsutil)

EOF
}

ensure_lib() {
  [[ -d "$LIB_DIR" ]] || die "Support files directory not found: $LIB_DIR"
}

ensure_cache_dir() {
  local cache_dir
  cache_dir="$(dirname "$INSPECT_CACHE_FILE")"
  mkdir -p "$cache_dir"
}

ensure_log_dir() {
  mkdir -p "$LOG_DIR"
}

find_repo_dir() {
  declare -a candidates=()
  local candidate resolved

  if [[ -n "${INFR_REPO_DIR:-}" ]]; then
    candidates+=("${INFR_REPO_DIR}")
  fi

  if [[ -n "${SELF_DIR:-}" ]]; then
    candidates+=("$SELF_DIR")
    candidates+=("${SELF_DIR}/..")
  fi

  if [[ -n "${LIB_DIR:-}" ]]; then
    candidates+=("$LIB_DIR")
    candidates+=("${LIB_DIR}/..")
  fi

  candidates+=("${HOME}/infra-bootstrap")

  declare -a unique=()
  for candidate in "${candidates[@]}"; do
    [[ -n "$candidate" ]] || continue
    if ! resolved="$(cd "$candidate" 2>/dev/null && pwd)"; then
      continue
    fi
    local seen=0
    local existing
    for existing in "${unique[@]}"; do
      if [[ "$existing" == "$resolved" ]]; then
        seen=1
        break
      fi
    done
    if (( seen == 1 )); then
      continue
    fi
    unique+=("$resolved")
    if [[ -d "${resolved}/.git" ]]; then
      printf '%s\n' "$resolved"
      return 0
    fi
  done

  return 1
}

remove_path() {
  local sudo_cmd="$1"
  local target="$2"
  local description="$3"
  if [[ -z "${target:-}" ]]; then
    return 0
  fi

  local normalized="$target"
  if [[ -d "$target" ]]; then
    local dir_path
    if dir_path="$(cd "$target" 2>/dev/null && pwd)"; then
      normalized="$dir_path"
    fi
  else
    local parent_path
    parent_path="$(dirname "$target")"
    if [[ -d "$parent_path" ]]; then
      local parent_real
      if parent_real="$(cd "$parent_path" 2>/dev/null && pwd)"; then
        normalized="${parent_real}/$(basename "$target")"
      fi
    fi
  fi

  target="$normalized"

  if [[ -z "$target" || "$target" == "/" ]]; then
    log "Refusing to remove ${description}: unsafe target '${target:-}'."
    return 1
  fi

  if [[ ! -e "$target" ]]; then
    log "${description} not found at ${target}."
    return 0
  fi

  if rm -rf "$target" 2>/dev/null; then
    log "Removed ${description} at ${target}."
    return 0
  fi

  if [[ -n "$sudo_cmd" ]]; then
    if $sudo_cmd rm -rf "$target"; then
      log "Removed ${description} at ${target} (with sudo)."
      return 0
    fi
  fi

  log "Failed to remove ${description} at ${target}."
  return 1
}

run_script() {
  local script="$1"
  shift || true
  ensure_lib
  local script_path="${LIB_DIR}/${script}"
  [[ -f "$script_path" ]] || die "Missing helper script: $script_path"
  ensure_log_dir
  local log_label="${script%.sh}"
  local timestamp
  timestamp="$(date -u +'%Y%m%dT%H%M%SZ')"
  local log_file="${LOG_DIR}/${log_label}_${timestamp}.log"
  log "Running ${script}..."
  set +e
  bash "$script_path" "$@" 2>&1 | tee "$log_file"
  local rc=${PIPESTATUS[0]}
  set -e
  if [[ $rc -ne 0 ]]; then
    log "${script} failed (exit ${rc}). See ${log_file} for details."
    return "$rc"
  fi
  log "${script} completed. Log stored at ${log_file}."
}

bootstrap_core() {
  run_script "1password_cli.sh"
  run_script "git_setup.sh"
  log "Core bootstrap complete."
}

update_infr() {
  if ! command -v git >/dev/null 2>&1; then
    die "git is required to run 'infr update'."
  fi

  local repo_dir
  if ! repo_dir="$(find_repo_dir)"; then
    die "Unable to locate infra-bootstrap git repository. Set INFR_REPO_DIR to override."
  fi

  log "Updating infra-bootstrap repository at ${repo_dir}..."

  local status_out
  status_out="$(git -C "$repo_dir" status --porcelain 2>/dev/null || true)"
  if [[ -n "$status_out" ]]; then
    die "Repository at ${repo_dir} has local modifications. Commit or stash them before updating."
  fi

  if ! git -C "$repo_dir" fetch --prune; then
    die "git fetch failed for repository ${repo_dir}."
  fi

  local upstream_ref
  upstream_ref="$(git -C "$repo_dir" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  if [[ -z "$upstream_ref" ]]; then
    local current_branch remote_name
    current_branch="$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    remote_name="$(git -C "$repo_dir" remote 2>/dev/null | head -n1 || true)"
    if [[ -z "$current_branch" || -z "$remote_name" ]]; then
      die "Repository at ${repo_dir} has no upstream configured; unable to determine update target."
    fi
    upstream_ref="${remote_name}/${current_branch}"
  fi

  if ! git -C "$repo_dir" merge --ff-only "$upstream_ref"; then
    die "Fast-forward merge failed when updating ${repo_dir}. Manually reconcile the repository."
  fi

  log "Repository update complete."

  local repo_scripts="${repo_dir}/scripts"
  if [[ "$LIB_DIR" == "$repo_scripts" ]]; then
    log "Support scripts already sourced from repository; no refresh needed."
    return
  fi

  if [[ ! -d "$repo_scripts" ]]; then
    log "Support scripts not found at ${repo_scripts}; skipping library refresh."
    return
  fi

  local sudo_cmd=""
  if [[ "$EUID" -ne 0 && -z "${INFR_NO_SUDO:-}" ]]; then
    if command -v sudo >/dev/null 2>&1; then
      sudo_cmd="sudo"
    else
      die "Root privileges required to refresh support files in ${LIB_DIR}."
    fi
  fi

  local staging
  staging="$(mktemp -d)"
  if ! cp -R "${repo_scripts}/." "$staging/"; then
    rm -rf "$staging"
    die "Failed to stage updated support scripts."
  fi
  rm -f "${staging}/infr"

  if [[ -f "${repo_dir}/.env" ]]; then
    if ! cp "${repo_dir}/.env" "${staging}/.env"; then
      rm -rf "$staging"
      die "Failed to stage updated environment file."
    fi
  fi

  log "Refreshing support files in ${LIB_DIR}..."
  if [[ -z "${LIB_DIR:-}" ]]; then
    rm -rf "$staging"
    die "Support directory LIB_DIR is not set; aborting refresh."
  fi
  if [[ -n "$sudo_cmd" ]]; then
    if ! $sudo_cmd rm -rf "$LIB_DIR"; then
      rm -rf "$staging"
      die "Failed to remove existing support files at ${LIB_DIR}."
    fi
    if ! $sudo_cmd mkdir -p "$LIB_DIR"; then
      rm -rf "$staging"
      die "Failed to recreate support directory ${LIB_DIR}."
    fi
    if ! $sudo_cmd cp -R "${staging}/." "$LIB_DIR/"; then
      rm -rf "$staging"
      die "Failed to install refreshed support files into ${LIB_DIR}."
    fi
  else
    if ! rm -rf "$LIB_DIR"; then
      rm -rf "$staging"
      die "Failed to remove existing support files at ${LIB_DIR}."
    fi
    if ! mkdir -p "$LIB_DIR"; then
      rm -rf "$staging"
      die "Failed to recreate support directory ${LIB_DIR}."
    fi
    if ! cp -R "${staging}/." "$LIB_DIR/"; then
      rm -rf "$staging"
      die "Failed to install refreshed support files into ${LIB_DIR}."
    fi
  fi

  rm -rf "$staging"
  log "Support files refreshed."
}

declare -a SETUP_COMPONENTS=(
  "python"
  "cuda"
  "docker"
  "ml_packages"
  "wandb"
  "huggingface"
  "gcloud"
)

declare -a SETUP_REQUESTED=()
GC_SUBCOMMAND=""
declare -a GC_ARGS=()

resolve_setup_target() {
  local token="$1"
  [[ -n "$token" ]] || return 1
  token="$(printf '%s' "$token" | tr '[:upper:]' '[:lower:]')"
  token="${token//-/_}"
  case "$token" in
    python|py)
      printf 'component python\n'
      ;;
    cuda|gpu)
      printf 'component cuda\n'
      ;;
    docker|docker_engine)
      printf 'component docker\n'
      ;;
    ml|ml_packages|mlpackages|mlpkgs|packages|pip_packages|pytorch)
      printf 'component ml_packages\n'
      ;;
    wandb)
      printf 'component wandb\n'
      ;;
    hf|huggingface|hugging_face)
      printf 'component huggingface\n'
      ;;
    op|1password|onepassword|1p|opcli|op_cli)
      printf 'script 1password_cli.sh\n'
      ;;
    git|git_setup)
      printf 'script git_setup.sh\n'
      ;;
    gcloud|google_cloud|gsutil)
      printf 'component gcloud\n'
      ;;
    *)
      return 1
      ;;
  esac
}

INSPECT_TIMESTAMP=""

component_label() {
  case "$1" in
    python) echo "Python toolchain" ;;
    cuda) echo "CUDA drivers & toolkit" ;;
    docker) echo "Docker engine" ;;
    ml_packages) echo "ML Python packages" ;;
    wandb) echo "Weights & Biases CLI" ;;
    huggingface) echo "Hugging Face CLI" ;;
    gcloud) echo "Google Cloud SDK (gcloud + gsutil)" ;;
    *) die "Unknown component '$1'" ;;
  esac
}

component_script() {
  case "$1" in
    python) echo "install_python.sh" ;;
    cuda) echo "setup_cuda_python.sh" ;;
    docker) echo "install_docker.sh" ;;
    ml_packages) echo "install_packages.sh" ;;
    wandb) echo "wandb_setup.sh" ;;
    huggingface) echo "huggingface_setup.sh" ;;
    gcloud) echo "google_cloud/install_gcloud_cli.sh" ;;
    *) die "Unknown component '$1'" ;;
  esac
}

component_depends() {
  case "$1" in
    ml_packages) echo "python" ;;
    wandb) echo "python" ;;
    huggingface) echo "python" ;;
    *) ;;
  esac
}

set_component_state() {
  local component="$1"
  local status="$2"
  local detail="$3"
  printf -v "component_status_${component}" '%s' "$status"
  printf -v "component_detail_${component}" '%s' "$detail"
}

get_component_status() {
  local component="$1"
  local var="component_status_${component}"
  printf '%s' "${!var:-unknown}"
}

get_component_detail() {
  local component="$1"
  local var="component_detail_${component}"
  printf '%s' "${!var:-}"
}

component_status_python() {
  local missing=()
  local details=()
  if command -v python3 >/dev/null 2>&1; then
    details+=("$(python3 --version 2>&1 | tr -d '\n')")
  else
    missing+=("python3")
  fi

  if command -v pip3 >/dev/null 2>&1; then
    details+=("$(pip3 --version 2>&1 | tr -d '\n')")
  else
    missing+=("pip3")
  fi

  if ((${#missing[@]} == 0)); then
    printf 'installed|%s' "$(IFS='; '; echo "${details[*]}")"
  else
    printf 'missing|Missing: %s' "$(IFS=', '; echo "${missing[*]}")"
  fi
}

component_status_cuda() {
  local missing=()
  local details=()

  if command -v nvidia-smi >/dev/null 2>&1; then
    local driver
    driver="$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -n1 | tr -d '\n')"
    details+=("Driver ${driver:-detected}")
  else
    missing+=("nvidia-smi")
  fi

  if command -v nvcc >/dev/null 2>&1; then
    local toolkit
    toolkit="$(nvcc --version | awk '/release/ {print $NF}' | sed 's/,//' | head -n1)"
    details+=("CUDA ${toolkit:-detected}")
  else
    missing+=("nvcc")
  fi

  if ((${#missing[@]} == 0)); then
    printf 'installed|%s' "$(IFS='; '; echo "${details[*]}")"
  else
    printf 'missing|Missing: %s' "$(IFS=', '; echo "${missing[*]}")"
  fi
}

component_status_docker() {
  if command -v docker >/dev/null 2>&1; then
    printf 'installed|%s' "$(docker --version 2>/dev/null | tr -d '\n')"
  else
    printf 'missing|docker command not found'
  fi
}

component_status_ml_packages() {
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'missing|python3 not available'
    return
  fi

  local python_code
  python_code=$'import importlib, sys\nmods = ["torch", "torchvision", "transformers", "datasets", "nvitop"]\nmissing = []\nreport = []\nfor name in mods:\n    try:\n        module = importlib.import_module(name)\n        ver = getattr(module, "__version__", "unknown")\n        report.append(f"{name} {ver}")\n    except Exception as exc:\n        missing.append(name)\nif missing:\n    print("missing|" + ", ".join(missing))\nelse:\n    print("installed|" + "; ".join(report))\n'

  local report status detail
  set +e
  report="$(python3 -c "$python_code" 2>/dev/null)"
  local py_status=$?
  set -e

  if [[ $py_status -ne 0 || -z "$report" ]]; then
    printf 'missing|Unable to inspect packages (python3 execution failed)'
    return
  fi

  IFS='|' read -r status detail <<<"$report"
  printf '%s|%s' "$status" "$detail"
}

component_status_wandb() {
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'missing|python3 not available'
    return
  fi

  if python3 -m pip show wandb >/dev/null 2>&1; then
    local version
    version="$(python3 -m pip show wandb 2>/dev/null | awk -F': ' '/^Version/ {print $2; exit}' | tr -d '\n')"
    printf 'installed|Version %s' "${version:-detected}"
  else
    printf 'missing|wandb package not found'
  fi
}

component_status_huggingface() {
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'missing|python3 not available'
    return
  fi

  if ! command -v huggingface-cli >/dev/null 2>&1; then
    printf 'missing|huggingface-cli not found'
    return
  fi

  if ! python3 -m pip show huggingface_hub >/dev/null 2>&1; then
    printf 'missing|huggingface_hub package not found'
    return
  fi

  local info username
  if info="$(huggingface-cli whoami 2>/dev/null)"; then
    username="$(printf '%s' "$info" | awk -F': ' '/^username/ {print $2; exit}')"
    username="${username:-detected}"
    printf 'installed|Authenticated as %s' "$username"
  else
    printf 'missing|huggingface-cli not authenticated'
  fi
}

component_status_gcloud() {
  local missing=()
  local details=()

  if command -v gcloud >/dev/null 2>&1; then
    local gcloud_version
    gcloud_version="$(gcloud --version 2>/dev/null | head -n1 | tr -d '\r')"
    gcloud_version="${gcloud_version:-gcloud detected}"
    details+=("$gcloud_version")
  else
    missing+=("gcloud")
  fi

  if command -v gsutil >/dev/null 2>&1; then
    local gsutil_version
    gsutil_version="$(gsutil version 2>/dev/null | head -n1 | tr -d '\r')"
    gsutil_version="${gsutil_version:-gsutil detected}"
    details+=("$gsutil_version")
  else
    missing+=("gsutil")
  fi

  if ((${#missing[@]} == 0)); then
    printf 'installed|%s' "$(IFS='; '; echo "${details[*]}")"
  else
    printf 'missing|Missing: %s' "$(IFS=', '; echo "${missing[*]}")"
  fi
}

run_component_check() {
  local component="$1"
  case "$component" in
    python) component_status_python ;;
    cuda) component_status_cuda ;;
    docker) component_status_docker ;;
    ml_packages) component_status_ml_packages ;;
    wandb) component_status_wandb ;;
    huggingface) component_status_huggingface ;;
    gcloud) component_status_gcloud ;;
    *) die "Unknown component '$component'" ;;
  esac
}

collect_component_status() {
  INSPECT_TIMESTAMP="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
  for component in "${SETUP_COMPONENTS[@]}"; do
    local result status detail
    result="$(run_component_check "$component")"
    IFS='|' read -r status detail <<<"$result"
    set_component_state "$component" "${status:-unknown}" "$detail"
  done
}

write_inspect_cache() {
  ensure_cache_dir
  local tmp_file
  tmp_file="$(mktemp "${INSPECT_CACHE_FILE}.XXXX")"
  {
    printf 'inspect_timestamp=%q\n' "$INSPECT_TIMESTAMP"
    for component in "${SETUP_COMPONENTS[@]}"; do
      printf 'component_%s_status=%q\n' "$component" "$(get_component_status "$component")"
      printf 'component_%s_detail=%q\n' "$component" "$(get_component_detail "$component")"
    done
  } >"$tmp_file"
  mv "$tmp_file" "$INSPECT_CACHE_FILE"
}

load_inspect_cache() {
  [[ -f "$INSPECT_CACHE_FILE" ]] || return 1
  # shellcheck source=/dev/null
  source "$INSPECT_CACHE_FILE"
  INSPECT_TIMESTAMP="${inspect_timestamp:-unknown}"
  for component in "${SETUP_COMPONENTS[@]}"; do
    local status_var="component_${component}_status"
    local detail_var="component_${component}_detail"
    set_component_state "$component" "${!status_var:-unknown}" "${!detail_var:-}"
  done
  return 0
}

print_component_summary() {
  local mode="$1"
  local ts="${INSPECT_TIMESTAMP:-unknown}"
  printf '\n== Component Status (%s) ==\n' "$mode"
  printf ' - Last update: %s\n' "$ts"
  for component in "${SETUP_COMPONENTS[@]}"; do
    local label
    label="$(component_label "$component")"
    local status
    status="$(get_component_status "$component")"
    local detail
    detail="$(get_component_detail "$component")"
    local status_label
    case "$status" in
      installed) status_label="Installed" ;;
      missing) status_label="Missing" ;;
      *) status_label="$status" ;;
    esac
    if [[ -n "$detail" ]]; then
      printf ' - %s: %s (%s)\n' "$label" "$status_label" "$detail"
    else
      printf ' - %s: %s\n' "$label" "$status_label"
    fi
  done
  printf '\n'
}

perform_inspection() {
  local mode="$1"
  if [[ "$mode" == "cached" ]]; then
    if load_inspect_cache; then
      print_component_summary "cached"
    else
      log "No cached inspection available; running a fresh inspection."
      perform_inspection "fresh"
    fi
    return
  fi

  ensure_lib
  run_script "inspect_system.sh"
  collect_component_status
  write_inspect_cache
  print_component_summary "fresh"
}

check_dependencies_satisfied() {
  local component="$1"
  local deps
  deps="$(component_depends "$component")"
  [[ -z "$deps" ]] && return 0
  local dep
  for dep in $deps; do
    if [[ "$(get_component_status "$dep")" != "installed" ]]; then
      return 1
    fi
  done
  return 0
}

install_component() {
  local component="$1"
  local label
  label="$(component_label "$component")"
  local script
  script="$(component_script "$component")"
  [[ -n "$script" ]] || die "No installer defined for component '$component'"

  if ! check_dependencies_satisfied "$component"; then
    local deps_list
    deps_list="$(component_depends "$component")"
    log "${label} depends on: ${deps_list}. Install prerequisites first."
    return
  fi

  if [[ "$component" == "ml_packages" ]]; then
    local env_dir="${ML_ENV_DIR:-$HOME/.infr/ml-venv}"
    ENV_DIR="$env_dir" run_script "$script"
  else
    run_script "$script"
  fi

  # Re-inspect to keep cache accurate (updates dependencies too).
  collect_component_status
  write_inspect_cache
  local status
  status="$(get_component_status "$component")"
  local detail
  detail="$(get_component_detail "$component")"
  if [[ "$status" == "installed" ]]; then
    log "${label} installation verified."
  else
    log "${label} still reports as '${status}'. Review logs above."
  fi
}

run_gc_command() {
  local subcommand="${1:-}"
  shift || true

  case "$subcommand" in
    ""|-h|--help|help)
      cat <<'EOF'
Usage: infr gc <subcommand> [args]

Subcommands:
  setup_project   Authenticate and configure gcloud for a project (wraps google_cloud/setup_gcloud_project.sh)
  create_bucket   Create a bucket and grant access (wraps google_cloud/create_bucket_with_access.sh)
  upload          Upload a run directory to GCS (wraps google_cloud/upload_run_to_gcs.sh)
EOF
      return 0
      ;;
    setup_project)
      run_script "google_cloud/setup_gcloud_project.sh" "$@"
      ;;
    create_bucket)
      run_script "google_cloud/create_bucket_with_access.sh" "$@"
      ;;
    upload)
      run_script "google_cloud/upload_run_to_gcs.sh" "$@"
      ;;
    *)
      die "Unknown Google Cloud subcommand '${subcommand}'. Use 'infr gc --help' for options."
      ;;
  esac
}

setup_interactive() {
  local -a requested=("$@")

  if ((${#requested[@]} > 0)); then
    local -a ordered_targets=()
    local token resolved target_type target_value key
    local need_inspection=0

    for token in "${requested[@]}"; do
      if ! resolved="$(resolve_setup_target "$token")"; then
        die "Unknown setup target '$token'. Use 'infr --help' to list supported names."
      fi
      target_type="${resolved%% *}"
      target_value="${resolved#* }"
      key="${target_type}:${target_value}"
      if [[ " ${ordered_targets[*]} " != *" ${key} "* ]]; then
        ordered_targets+=("$key")
        if [[ "$target_type" == "component" ]]; then
          need_inspection=1
        fi
      fi
    done

    if (( need_inspection )); then
      perform_inspection "fresh"
    fi

    log "Executing setup targets: ${requested[*]}"

    local -a failures=()

    for key in "${ordered_targets[@]}"; do
      target_type="${key%%:*}"
      target_value="${key#*:}"
      case "$target_type" in
        component)
          local label
          label="$(component_label "$target_value")"
          if ! install_component "$target_value"; then
            failures+=("$label")
          fi
          ;;
        script)
          if ! run_script "$target_value"; then
            failures+=("$target_value")
          fi
          ;;
        *)
          die "Unhandled setup target type '$target_type' for '$key'"
          ;;
      esac
    done

    if (( need_inspection )); then
      print_component_summary "cached"
    fi

    if ((${#failures[@]} > 0)); then
      log "Targeted setup completed with failures: ${failures[*]}."
      return 1
    fi

    log "Targeted setup complete."
    return 0
  fi

  perform_inspection "fresh"

  declare -a decision_components=()
  declare -a to_install=()
  local auto_mode="false"
  local missing_seen=0
  local forced_refresh_seen=0

  if [[ ! -t 0 ]]; then
    auto_mode="true"
  fi

  if [[ -n "${INFR_AUTO_INSTALL:-}" ]]; then
    local auto_setting
    auto_setting="$(printf '%s' "${INFR_AUTO_INSTALL:-}" | tr '[:upper:]' '[:lower:]')"
    case "$auto_setting" in
      1|true|yes) auto_mode="true" ;;
    esac
  fi

  if [[ "$auto_mode" == "true" ]]; then
    log "Auto-install mode enabled; missing components will be queued without prompts."
  fi

  for component in "${SETUP_COMPONENTS[@]}"; do
    local label
    label="$(component_label "$component")"
    local status
    status="$(get_component_status "$component")"
    local detail
    detail="$(get_component_detail "$component")"

    if [[ "$status" == "installed" ]]; then
      if [[ "$component" == "wandb" || "$component" == "huggingface" ]]; then
        if [[ " ${to_install[*]} " != *" $component "* ]]; then
          to_install+=("$component")
        fi
        forced_refresh_seen=1
        log "${label} already present (${detail:-ok}). Refreshing credentials."
        continue
      fi
      log "${label} already present (${detail:-ok}). Skipping."
      continue
    fi

    missing_seen=1

    if [[ "$auto_mode" == "true" ]]; then
      to_install+=("$component")
      log "Auto-queued ${label} for installation."
      continue
    fi

    decision_components+=("$component")
  done

  if (( missing_seen == 0 )) && (( forced_refresh_seen == 0 )); then
    print_component_summary "cached"
    log "Setup flow complete."
    return
  fi

  if [[ "$auto_mode" == "false" ]] && ((${#decision_components[@]} > 0)); then
    log "Review missing components below; installations will run after all prompts are answered."

    for component in "${decision_components[@]}"; do
      local label
      label="$(component_label "$component")"
      local detail
      detail="$(get_component_detail "$component")"

      printf '\n%s appears missing (%s).\n' "$label" "${detail:-no detail}"
      if ! check_dependencies_satisfied "$component"; then
        local deps_list
        deps_list="$(component_depends "$component")"
        if [[ -n "$deps_list" ]]; then
          printf '%s depends on %s; make sure to install them first.\n' "$label" "$deps_list"
        fi
      fi

      local response
      while true; do
        read -r -p "Install ${label} after prompts? [y/N] " response || response=""
        case "$response" in
          [Yy])
            to_install+=("$component")
            log "Queued ${label} for installation."
            break
            ;;
          [Nn]|"")
            log "Skipping ${label}."
            break
            ;;
          *)
            printf "Please answer y or n.\n"
            ;;
        esac
      done
    done
  fi

  if ((${#to_install[@]} == 0)); then
    log "No installations queued."
    print_component_summary "cached"
    log "Setup flow complete."
    return
  fi

  log "Beginning queued installations..."
  declare -a failed_components=()
  for component in "${SETUP_COMPONENTS[@]}"; do
    if [[ " ${to_install[*]} " == *" $component "* ]]; then
      if ! install_component "$component"; then
        failed_components+=("$component")
      fi
    fi
  done

  print_component_summary "cached"
  if ((${#failed_components[@]} > 0)); then
    local labels=()
    local failed
    for failed in "${failed_components[@]}"; do
      labels+=("$(component_label "$failed")")
    done
    log "Setup completed with failures: ${labels[*]}. Review logs under ${LOG_DIR}."
    return 1
  fi
  log "Setup flow complete."
}

uninstall_infr() {
  log "Starting infr uninstall..."

  local errors=0
  local sudo_cmd=""
  if [[ "$EUID" -ne 0 && -z "${INFR_NO_SUDO:-}" ]]; then
    if command -v sudo >/dev/null 2>&1; then
      sudo_cmd="sudo"
    fi
  fi

  if [[ -n "$sudo_cmd" ]]; then
    log "Using sudo for privileged file removals."
  fi

  local -a repo_candidates=()
  if [[ -n "${INFR_REPO_DIR:-}" ]]; then
    repo_candidates+=("${INFR_REPO_DIR}")
  fi
  repo_candidates+=("${HOME}/infra-bootstrap")
  local repo_from_self=""
  if repo_from_self="$(cd "${SELF_DIR}/.." 2>/dev/null && pwd)"; then
    repo_candidates+=("$repo_from_self")
  fi

  local -a seen_repos=()
  local repo_removed=0
  local repo_candidate
  for repo_candidate in "${repo_candidates[@]}"; do
    [[ -n "${repo_candidate:-}" ]] || continue
    local already_seen=0
    local listed
    for listed in "${seen_repos[@]}"; do
      if [[ "$listed" == "$repo_candidate" ]]; then
        already_seen=1
        break
      fi
    done
    if (( already_seen == 1 )); then
      continue
    fi
    seen_repos+=("$repo_candidate")

    if [[ ! -d "$repo_candidate" ]]; then
      continue
    fi
    if [[ ! -f "${repo_candidate}/install.sh" || ! -f "${repo_candidate}/scripts/infr" ]]; then
      continue
    fi

    if remove_path "$sudo_cmd" "$repo_candidate" "infra-bootstrap repository"; then
      repo_removed=1
      break
    else
      errors=1
    fi
  done

  if (( repo_removed == 0 )); then
    log "infra-bootstrap repository not detected; skipping removal."
  fi

  if [[ -d "$LIB_DIR" ]]; then
    if ! remove_path "$sudo_cmd" "$LIB_DIR" "support files directory"; then
      errors=1
    fi
  elif (( repo_removed == 0 )); then
    log "Support files directory not found at ${LIB_DIR}."
  fi

  local default_cache_root="${HOME}/.cache/infr"
  local cache_root_removed=0
  if [[ "${INSPECT_CACHE_FILE}" == "${default_cache_root}"* || "${LOG_DIR}" == "${default_cache_root}"* ]]; then
    if [[ -e "$default_cache_root" ]]; then
      if remove_path "$sudo_cmd" "$default_cache_root" "cache directory"; then
        cache_root_removed=1
      else
        errors=1
      fi
    fi
  fi

  if (( cache_root_removed == 0 )); then
    if [[ -e "$INSPECT_CACHE_FILE" ]]; then
      if ! remove_path "$sudo_cmd" "$INSPECT_CACHE_FILE" "inspect cache file"; then
        errors=1
      fi
    else
      log "Inspect cache file not found at ${INSPECT_CACHE_FILE}."
    fi

    if [[ -d "$LOG_DIR" ]]; then
      if ! remove_path "$sudo_cmd" "$LOG_DIR" "log directory"; then
        errors=1
      fi
    else
      log "Log directory not found at ${LOG_DIR}."
    fi
  fi

  local -a cli_candidates=()
  local cli_path
  cli_path="$(command -v "$PROGRAM" 2>/dev/null || true)"
  if [[ -n "$cli_path" ]]; then
    cli_candidates+=("$cli_path")
  fi
  if [[ -n "${INFR_BIN_DIR:-}" ]]; then
    cli_candidates+=("${INFR_BIN_DIR}/${PROGRAM}")
  else
    cli_candidates+=("/usr/local/bin/${PROGRAM}")
  fi
  if [[ -n "${INSTALL_PREFIX:-}" ]]; then
    cli_candidates+=("${INSTALL_PREFIX}/${PROGRAM}")
  fi

  local cli_removed=0
  local cli_candidate
  for cli_candidate in "${cli_candidates[@]}"; do
    [[ -n "${cli_candidate:-}" ]] || continue
    if [[ ! -e "$cli_candidate" ]]; then
      continue
    fi
    if remove_path "$sudo_cmd" "$cli_candidate" "CLI launcher"; then
      cli_removed=1
    else
      errors=1
    fi
  done
  if (( cli_removed == 0 )); then
    log "CLI launcher not found; nothing to remove."
  fi

  if (( errors > 0 )); then
    die "Uninstall encountered failures."
  fi

  log "infr uninstall complete."
}

command=""
inspect_mode="fresh"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --debug)
      DEBUG_MODE="true"
      shift
      ;;
    --cached)
      inspect_mode="cached"
      shift
      ;;
    bootstrap|base|core)
      command="bootstrap"
      shift
      ;;
    inspect)
      command="inspect"
      shift
      ;;
    setup)
      command="setup"
      shift
      SETUP_REQUESTED=("$@")
      break
      ;;
    gc)
      command="gc"
      shift
      if [[ $# -gt 0 ]]; then
        GC_SUBCOMMAND="$1"
        shift
      else
        GC_SUBCOMMAND=""
      fi
      GC_ARGS=("$@")
      break
      ;;
    uninstall)
      command="uninstall"
      shift
      ;;
    update)
      command="update"
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument '$1'. Use --help for usage."
      ;;
  esac
done

if [[ -z "$command" ]]; then
  command="bootstrap"
fi

if [[ "$inspect_mode" == "cached" && "$command" != "inspect" ]]; then
  die "--cached can only be used with 'infr inspect'."
fi

export INFR_DEBUG="$DEBUG_MODE"

case "$command" in
  bootstrap) bootstrap_core ;;
  inspect) perform_inspection "$inspect_mode" ;;
  setup) setup_interactive "${SETUP_REQUESTED[@]}" ;;
  update) update_infr ;;
  uninstall) uninstall_infr ;;
  gc) run_gc_command "$GC_SUBCOMMAND" "${GC_ARGS[@]}" ;;
  *)
    die "Unhandled command '$command'"
    ;;
esac
